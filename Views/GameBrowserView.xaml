<UserControl x:Class="ChessProject.Views.GameBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ChessProject.Converters"
             Background="#1E1E1E">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Border Padding="16">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Chess.com Game Browser"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,12"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusColor}"
                       FontWeight="Bold"
                       Margin="400,0,0,0"/>

            <!-- Search -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <!-- Username -->
                    <ColumnDefinition Width="200"/>
                    <!-- Search -->
                    <ColumnDefinition Width="134"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="6"/>
                    <!-- Add Favourite -->
                    <ColumnDefinition Width="120"/>
                    <!-- Favourite Players -->
                    <ColumnDefinition Width="120"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="70"/>
                    <!-- Online -->
                    <ColumnDefinition Width="110"/>
                    <!-- Saved -->
                    <ColumnDefinition Width="110"/>
                    <!-- Recent -->
                    <ColumnDefinition Width="110"/>
                    <!-- Fills remaining space -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,10,0"
                         Text="{Binding Username}"
                         ToolTip="Enter Chess.com username"/>

                <Button Grid.Column="1"
                        Content="Search"
                        Command="{Binding SearchPlayerCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Content="Add To Favourite"
                        Command="{Binding SaveFavouritePlayerCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="4"
                        Content="Show Favourites"
                        Command="{Binding ShowFavouritePlayersCommand}"/>

                <Button Grid.Column="6"
                        Content="Online"
                        Command="{Binding ShowOnlineCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="7"
                        Content="Saved"
                        Command="{Binding ShowSavedCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="8"
                        Content="Recent"
                        Command="{Binding ShowRecentCommand}"
                        Margin="0,0,10,0"/>
            </Grid>

            <!-- Archives + Games -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Archives -->
                <StackPanel Grid.Column="0"
                            Visibility="{Binding IsArchiveModeVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Game Archives"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding Archives}"
                             SelectedItem="{Binding SelectedArchive}"
                             DisplayMemberPath="DisplayName"
                             Height="400"/>

                    <Button Content="Load Archive"
                            Margin="0,8,0,0"
                            Command="{Binding LoadArchiveCommand}"/>
                </StackPanel>

                <!-- Favourite Players -->
                <StackPanel Grid.Column="0"
                            Visibility="{Binding IsFavouritePlayersVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Favourite Players"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding FavouritePlayers}"
                             SelectedItem="{Binding SelectedFavouritePlayer}"
                             Height="400"/>
                </StackPanel>

                <!-- Games -->
                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0">

                    <TextBlock Text="Games"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding DisplayGames}"
                             SelectedItem="{Binding SelectedGame}"
                             Height="400">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Padding="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>

            </Grid>

        </Grid>

    </Border>
</UserControl>