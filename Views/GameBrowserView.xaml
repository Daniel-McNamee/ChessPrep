<UserControl x:Class="ChessProject.Views.GameBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ChessProject.Converters"
             Background="#1E1E1E">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Padding="16">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Chess.com Game Browser"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,12"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusColor}"
                       FontWeight="Bold"
                       Margin="400,0,0,0"/>

            <!-- Search -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <!-- Username -->
                    <ColumnDefinition Width="200"/>
                    <!-- Search -->
                    <ColumnDefinition Width="134"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="6"/>
                    <!-- Add Favourite -->
                    <ColumnDefinition Width="120"/>
                    <!-- Favourite Players -->
                    <ColumnDefinition Width="120"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="70"/>
                    <!-- Local Games -->
                    <ColumnDefinition Width="110"/>
                    <!-- Saved -->
                    <ColumnDefinition Width="110"/>
                    <!-- Recent -->
                    <ColumnDefinition Width="110"/>
                    <!-- Fills remaining space -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,10,0"
                         Text="{Binding Username}"
                         ToolTip="Enter Chess.com username"/>

                <Button Grid.Column="1"
                        Content="Search"
                        Command="{Binding SearchPlayerCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Content="Add To Favourite"
                        Command="{Binding SaveFavouritePlayerCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="4"
                        Content="Show Favourites"
                        Command="{Binding ShowFavouritePlayersCommand}"/>

                <Button Grid.Column="6"
                        Content="Local Games"
                        Command="{Binding ShowLocalGamesCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="7"
                        Content="Saved"
                        Command="{Binding ShowSavedCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="8"
                        Content="Recent"
                        Command="{Binding ShowRecentCommand}"
                        Margin="0,0,10,0"/>
            </Grid>

            <!-- Archives + Games -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Archives -->
                <StackPanel Grid.Column="0"
                            Visibility="{Binding IsArchiveModeVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Game Archives"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding Archives}"
                             SelectedItem="{Binding SelectedArchive}"
                             DisplayMemberPath="DisplayName"
                             Height="400"/>

                    <Button Content="Load Archive"
                            Margin="0,8,0,0"
                            Command="{Binding LoadArchiveCommand}"/>
                </StackPanel>

                <!-- Favourite Players -->
                <StackPanel Grid.Column="0"
                            Visibility="{Binding IsFavouritePlayersVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Favourite Players"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding FavouritePlayers}"
                             SelectedItem="{Binding SelectedFavouritePlayer}"
                             Height="400">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding}"
                                               Padding="4"
                                               VerticalAlignment="Center"/>

                                    <!-- Delete Favourite Player -->
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Width="18"
                                            Height="18"
                                            Margin="6,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.DeleteFavouritePlayerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Foreground" Value="#888"/>
                                                <Setter Property="Opacity" Value="0.6"/>

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </StackPanel>

                <!-- Games -->
                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0">

                    <TextBlock Text="Games"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding DisplayGames}"
                             SelectedItem="{Binding SelectedGame}"
                             Height="400">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding}"
                                               Padding="4"
                                               VerticalAlignment="Center"/>

                                    <!-- Delete Game -->
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Width="18"
                                            Height="18"
                                            Margin="6,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            CommandParameter="{Binding}">

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Command"
                                                        Value="{Binding DataContext.DeleteSavedGameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Foreground" Value="#888"/>
                                                <Setter Property="Opacity" Value="0.6"/>

                                                <Style.Triggers>

                                                    <!-- Saved -->
                                                    <DataTrigger Binding="{Binding DataContext.IsSavedMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Command"
                                                                Value="{Binding DataContext.DeleteSavedGameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                                    </DataTrigger>

                                                    <!-- Local -->
                                                    <DataTrigger Binding="{Binding DataContext.IsLocalMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Command"
                                                                Value="{Binding DataContext.DeleteLocalGameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                                    </DataTrigger>

                                                    <!-- Hover -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>

            </Grid>

        </Grid>

    </Border>
</UserControl>