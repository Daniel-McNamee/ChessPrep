<UserControl x:Class="ChessProject.Views.GameBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <Border Padding="16">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Chess.com Game Browser"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,12"/>

            <!-- Search -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="134"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,10,0"
                         Text="{Binding Username}"
                         ToolTip="Enter Chess.com username"/>

                <Button Grid.Column="1"
                        Content="Search"
                        Command="{Binding SearchPlayerCommand}"
                        Width="134"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Content="Online"
                        Command="{Binding ShowOnlineCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="4"
                        Content="Saved"
                        Command="{Binding ShowSavedCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="5"
                        Content="Recent"
                        Command="{Binding ShowRecentCommand}"/>
            </Grid>

            <!-- Archives + Games -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Archives -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Game Archives"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding Archives}"
                             SelectedItem="{Binding SelectedArchive}"
                             DisplayMemberPath="DisplayName"
                             Height="400"/>

                    <Button Content="Load Archive"
                            Margin="0,8,0,0"
                            Command="{Binding LoadArchiveCommand}"/>

                </StackPanel>

                <!-- Games -->
                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0">

                    <TextBlock Text="Games"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding DisplayGames}"
                             SelectedItem="{Binding SelectedGame}"
                             Height="400">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Padding="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>

            </Grid>

        </Grid>

    </Border>
</UserControl>