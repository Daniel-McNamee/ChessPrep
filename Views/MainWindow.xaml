<Window x:Class="ChessProject.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ChessProject.Views"
        Title="Chess Project"
        Height="750"
        Width="1025">

    <!-- Headers -->
    <TabControl SelectedIndex="{Binding SelectedTabIndex}">

        <TabItem Header="Board">
            <views:BoardView DataContext="{Binding BoardViewModel}"/>
        </TabItem>

        <TabItem Header="Opening Browser">
            <views:OpeningBrowserView DataContext="{Binding OpeningBrowserViewModel}"/>
        </TabItem>

        <TabItem Header="Game Browser">
            <views:GameBrowserView DataContext="{Binding GameBrowserViewModel}"/>
        </TabItem>

    </TabControl>


</Window>
