<UserControl x:Class="ChessProject.Views.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ChessProject.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Chess Board -->
        <Border Grid.Column="0"
                Padding="10"
                Background="#333">

            <Border Width="560"
                    Height="560"
                    Background="Transparent">

                <ItemsControl ItemsSource="{Binding VisualSquares}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="8" Columns="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="70"
                                    Height="70"
                                    Background="{Binding SquareColor}"
                                    BorderThickness="3">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding LastMoveHighlight}"
                                                         Value="Normal">
                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding LastMoveHighlight}"
                                                         Value="Capture">
                                                <Setter Property="BorderBrush" Value="#FF4C4C"/>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Image Source="{Binding PieceImagePath}"
                                       Stretch="Uniform"/>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Border>
        </Border>

        <!-- Side Panel -->
        <Border Grid.Column="1"
                Padding="16"
                Background="#222">

            <StackPanel Orientation="Vertical"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Width="260">

                <!-- OPENING INFO -->
                <StackPanel Visibility="{Binding IsOpeningMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Opening"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding OpeningName}"
                               FontSize="14"
                               Foreground="White"
                               TextWrapping="Wrap"
                               MaxWidth="240"/>

                    <TextBlock Text="{Binding ECOCode}"
                               FontSize="12"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,16"/>

                </StackPanel>

                <!-- GAME INFO -->
                <StackPanel Visibility="{Binding IsGameMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Game"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding WhitePlayer, StringFormat=White: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding WhiteRating, StringFormat=Rating: {0}}"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding BlackPlayer, StringFormat=Black: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding BlackRating, StringFormat=Rating: {0}}"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding GameResult, StringFormat=Result: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding GameTimeControl, StringFormat=Time Control: {0}}"
                               Foreground="White"
                               Margin="0,0,0,16"/>

                </StackPanel>


                <!-- CONTROLS -->
                <TextBlock Text="Controls"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">

                    <Button Content="⟲ Reset"
                            Width="70"
                            Margin="4"
                            Command="{Binding ResetCommand}"/>

                    <Button Content="◀"
                            Width="40"
                            Margin="4"
                            Command="{Binding PreviousCommand}"/>

                    <Button Content="▶"
                            Width="40"
                            Margin="4"
                            Command="{Binding NextCommand}"/>

                    <Button Content="⇅ Flip Board"
                            Width="100"
                            Margin="4"
                            Command="{Binding FlipBoardCommand}"/>

                </StackPanel>


                <!-- MOVE INFO -->
                <TextBlock Text="Move"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding CurrentMoveDisplay}"
                           FontSize="14"
                           Foreground="White"
                           Margin="0,0,0,8"/>


                <!-- MOVE LIST -->
                <ListBox x:Name="MoveList"
                         ItemsSource="{Binding DisplayMoves}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="200"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,0,0,16">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Notation}"
                                       Foreground="White"
                                       Padding="4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                    <Setter Property="Background" Value="#444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                </ListBox>


                <!-- OPENING STATISTICS -->
                <StackPanel Visibility="{Binding IsOpeningMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Statistics"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Vertical">

                        <TextBlock Text="{Binding WhiteWinPercentage, StringFormat=White Win: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                        <TextBlock Text="{Binding DrawPercentage, StringFormat=Draw: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                        <TextBlock Text="{Binding BlackWinPercentage, StringFormat=Black Win: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>