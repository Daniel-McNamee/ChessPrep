<UserControl x:Class="ChessProject.Views.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ChessProject.Converters"
             Focusable="True"
             KeyDown="UserControl_KeyDown">

    <UserControl.Resources>
        <!-- Converter to toggle visibility based on boolean properties -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/> 
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Chess Board -->
        <Border Grid.Column="0"
                Padding="10"
                Background="#333">

            <Border Width="560"
                    Height="560"
                    Background="Transparent">

                <!-- Using an ItemsControl with a UniformGrid to create the 8x8 chess board -->
                <ItemsControl ItemsSource="{Binding VisualSquares}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="8" Columns="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- Each square is represented by a Border that changes color based on its state and contains an Image for the piece -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="70"
                                    Height="70"
                                    Background="{Binding SquareColor}"
                                    BorderThickness="3">

                                <!-- Input binding to handle square clicks, passing the square's data context as a parameter to the command in the ViewModel -->
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SquareClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>

                                <!-- Style triggers to change the border color based on the square's state-->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>

                                        <Style.Triggers>

                                            <!-- Last Move Normal -->
                                            <DataTrigger Binding="{Binding LastMoveHighlight}"
                                                         Value="Normal">
                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                            </DataTrigger>

                                            <!-- Last Move Capture -->
                                            <DataTrigger Binding="{Binding LastMoveHighlight}"
                                                         Value="Capture">
                                                <Setter Property="BorderBrush" Value="#FF4C4C"/>
                                            </DataTrigger>

                                            <!-- In Check -->
                                            <DataTrigger Binding="{Binding IsInCheck}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF4C4C"/>
                                                <Setter Property="BorderThickness" Value="3"/>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <!-- Piece Image -->
                                <Image Source="{Binding PieceImagePath}"
                                       Stretch="Uniform"/>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Border>
        </Border>

        <!-- Side Panel -->
        <Border Grid.Column="1"
                Padding="16"
                Background="#222">

            <StackPanel Orientation="Vertical"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Width="260">

                <!-- OPENING INFO -->
                <StackPanel Visibility="{Binding IsOpeningMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Opening"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding OpeningName}"
                               FontSize="14"
                               Foreground="White"
                               TextWrapping="Wrap"
                               MaxWidth="240"/>

                    <TextBlock Text="{Binding ECOCode}"
                               FontSize="12"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,16"/>

                </StackPanel>

                <!-- GAME INFO -->
                <StackPanel Visibility="{Binding IsGameMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Game"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding CurrentTurnDisplay}"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding WhitePlayer, StringFormat=White: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding WhiteRating, StringFormat=Rating: {0}}"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding WhiteClock}"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,4,0,8"/>

                    <TextBlock Text="{Binding BlackPlayer, StringFormat=Black: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding BlackRating, StringFormat=Rating: {0}}"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding BlackClock}"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,4,0,8"/>

                    <TextBlock Text="{Binding GameResult, StringFormat=Result: {0}}"
                               Foreground="White"/>

                    <TextBlock Text="{Binding GameType}"
                               Foreground="White"
                               FontSize="12"/>

                    <TextBlock Text="{Binding TotalMoves, StringFormat=Total Moves: {0}}"
                               Foreground="White"/>

                </StackPanel>


                <!-- LOCAL GAME INFO -->
                <StackPanel Visibility="{Binding IsLocalGame, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,16">

                    <TextBlock Text="Local Game"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <!-- WHITE CLOCK -->
                    <Border Margin="0,5,0,5"
                            Padding="6"
                            CornerRadius="6">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="2"/>

                                <!-- Style triggers to highlight the active player's clock and indicate low/critical time -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTurn}" Value="White">
                                        <Setter Property="BorderBrush" Value="#00C896"/>
                                        <Setter Property="Background" Value="#1F3A33"/>
                                    </DataTrigger>
                                
                                    <!-- WARNING (30s) -->
                                    <DataTrigger Binding="{Binding IsWhiteLowTime}" Value="True">
                                        <Setter Property="Background" Value="#5A3A1F"/>
                                    </DataTrigger>

                                    <!-- DANGER (15s) -->
                                    <DataTrigger Binding="{Binding IsWhiteCriticalTime}" Value="True">
                                        <Setter Property="Background" Value="#5A1F1F"/>
                                        <Setter Property="BorderBrush" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="{Binding WhiteDisplay}"
                                       Foreground="White"
                                       FontSize="12"/>

                            <TextBlock Text="{Binding WhiteClockDisplay}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- BLACK CLOCK -->
                    <Border Margin="0,5,0,10"
                            Padding="6"
                            CornerRadius="6">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="2"/>

                                <!-- Style triggers to highlight the active player's clock and indicate low/critical time -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTurn}" Value="Black">
                                        <Setter Property="BorderBrush" Value="#00C896"/>
                                        <Setter Property="Background" Value="#1F3A33"/>
                                    </DataTrigger>

                                    <!-- WARNING (30s) -->
                                    <DataTrigger Binding="{Binding IsBlackLowTime}" Value="True">
                                        <Setter Property="Background" Value="#5A3A1F"/>
                                    </DataTrigger>

                                    <!-- DANGER (15s) -->
                                    <DataTrigger Binding="{Binding IsBlackCriticalTime}" Value="True">
                                        <Setter Property="Background" Value="#5A1F1F"/>
                                        <Setter Property="BorderBrush" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="{Binding BlackDisplay}"
                                       Foreground="White"
                                       FontSize="12"/>

                            <TextBlock Text="{Binding BlackClockDisplay}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- TIME CONTROL -->
                    <TextBlock Text="{Binding TimeDisplay}"
                               Foreground="#BBBBBB"
                               FontSize="12"
                               Margin="0,0,0,10"/>

                </StackPanel>


                <!-- CONTROLS -->
                <TextBlock Text="Controls"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">

                    <Button Content="⟲ Reset"
                            Width="70"
                            Margin="4"
                            Command="{Binding ResetCommand}"/>

                    <Button Content="◀"
                            Width="40"
                            Margin="4"
                            Command="{Binding PreviousCommand}"/>

                    <Button Content="▶"
                            Width="40"
                            Margin="4"
                            Command="{Binding NextCommand}"/>

                    <Button Content="⇅ Flip Board"
                            Width="100"
                            Margin="4"
                            Command="{Binding FlipBoardCommand}"/>

                </StackPanel>


                <!-- MOVE INFO -->
                <TextBlock Text="Move"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding CurrentMoveDisplay}"
                           FontSize="14"
                           Foreground="White"
                           Margin="0,0,0,8"/>


                <!-- MOVE LIST -->
                <ListBox x:Name="MoveList"
                         ItemsSource="{Binding DisplayMoves}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="200"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,0,0,16">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SelectMoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}" />
                                </Grid.InputBindings>
                                
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Move notation -->
                                <TextBlock Text="{Binding Notation}"
                                           Foreground="White"
                                           Padding="4"/>

                                <!-- Move note -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#2A2A2A"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="2"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <!-- Style triggers to highlight the current move in the move list -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                    <Setter Property="Background" Value="#444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                </ListBox>

                <!-- Save Game Button -->
                <Button Content="💾 Save Game"
                        Visibility="{Binding IsGameMode, Converter={StaticResource BoolToVisibilityConverter}}"
                        Width="100"
                        Margin="5"
                        Command="{Binding SaveGameCommand}"/>

                <!-- Favourite Opening Button -->
                <Button Content="★ Favourite Opening"
                        Visibility="{Binding IsOpeningMode, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding SaveFavouriteOpeningCommand}"
                        Width="150"
                        Margin="5"/>

                <!-- Status Message that displays things like save state and game result -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>


                <!-- OPENING STATISTICS -->
                <StackPanel Visibility="{Binding IsOpeningMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Statistics"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Vertical">

                        <TextBlock Text="{Binding WhiteWinPercentage, StringFormat=White Win: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                        <TextBlock Text="{Binding DrawPercentage, StringFormat=Draw: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                        <TextBlock Text="{Binding BlackWinPercentage, StringFormat=Black Win: {0}%}"
                                   Foreground="White"
                                   FontSize="12"/>

                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>